{
    "extends": "airbnb-base",
    "plugins": [
        "import"
    ],
  "parserOptions": {
    "sourceType": "script"
  },
  "env": {
    "node": true,
    "mocha": true,
    "es2020": true
  },
  "rules": {
    "no-param-reassign": ["error", {
      "props": false
    }],
    "strict": 0,
    "import/extensions": 0
  }
}
